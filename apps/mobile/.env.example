# Base URL for the Next.js API (apps/api).
# Must include the protocol and port. No trailing slash.
#
# Local Simulator/Emulator + API on the same machine:
#   http://localhost:3000
#
# Physical device on the same Wi-Fi (replace with your machine's LAN IP):
#   http://192.168.1.42:3000
#
# Defaults to http://localhost:3000 if not set.
EXPO_PUBLIC_API_URL=http://localhost:3000
